# ==============================================
# THE FIVE AGENT — Environment Variables
# ==============================================
# העתק קובץ זה ל-.env ומלא את הערכים האמיתיים
# Copy this file to .env and fill in real values
# ==============================================

# --- Claude / Anthropic ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Model (ברירת מחדל: claude-sonnet-4-6) ---
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- חן — כלי חיפוש (Brave Search) ---
BRAVE_API_KEY=your_brave_api_key_here

# --- יובל — יצירת תמונות ---
# בחר שירות: DALL-E / Replicate / Fal.ai / אחר
IMAGE_API_KEY=your_image_api_key_here
IMAGE_API_PROVIDER=dalle   # dalle | replicate | fal

# --- כללי ---
LOG_LEVEL=info
